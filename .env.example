# Lobrecs Agent reads provider credentials from the inherited shell env.
# Do not put real API keys in this file.

CLAUDE_COMMAND=claude
CODEX_COMMAND=codex
OPENCODE_COMMAND=opencode

# Optional provider keys are read by the underlying CLIs, not stored by the app.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
