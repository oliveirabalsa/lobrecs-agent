{
  "name": "lobrecs-agent",
  "version": "0.4.8",
  "description": "Electron desktop harness for AI coding agents, model routing, and swarm orchestration.",
  "productName": "Lobrecs Agent",
  "desktopName": "lobrecs-agent.desktop",
  "type": "module",
  "main": "./out/main/index.js",
  "author": {
    "name": "Lobrecs",
    "email": "contato@lobrecs.com"
  },
  "scripts": {
    "dev": "node scripts/ensure-electron-native.mjs && electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "pretest": "node scripts/ensure-node-native.mjs",
    "test": "vitest --passWithNoTests",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "rebuild:node": "npm rebuild better-sqlite3 node-pty",
    "build:mac": "node scripts/build-mac.mjs",
    "build:win": "node scripts/build-win.mjs",
    "build:linux": "npm run build && electron-builder --linux",
    "build:mac:release": "node scripts/build-mac.mjs --publish",
    "build:mac:local": "node scripts/build-mac.mjs --allow-unsigned",
    "release": "node scripts/release.mjs",
    "release:ci": "node scripts/release.mjs --ci",
    "release:local": "node scripts/release.mjs --local",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "build:deb": "npm run build && electron-builder --linux deb"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "better-sqlite3": "^12.4.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.6.2",
    "marked": "^14.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.17",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.14",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
